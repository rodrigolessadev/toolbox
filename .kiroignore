# ============================================================
# Kiro IDE — arquivos ignorados pelo contexto da IA
# O Kiro le este arquivo e NAO envia ao modelo os arquivos
# listados aqui. Use para excluir artefatos de build,
# binarios grandes, caches e tudo que nao ajuda a IA a
# entender o codigo.
# ============================================================

# Dependencias
node_modules/
**/node_modules/
.pnp/
.pnp.js
.npm/
.yarn/
.yarn-cache/

# Builds Rust (src-tauri/target pode ter GBs de binarios)
src-tauri/target/
**/target/
**/Cargo.lock

# Build outputs do frontend
dist/
build/
out/
.vite/
.tsbuildinfo
**/*.tsbuildinfo
.eslintcache
.stylelintcache
.parcel-cache/

# Artefatos gerados pelo Tauri
src-tauri/gen/
src-tauri/target/

# Releases (instaladores binarios)
releases/*.msi
releases/*.exe
releases/*.deb
releases/*.appimage
releases/*.dmg
releases/*.zip
releases/*.tar.gz
releases/*.tar.xz
releases/*.nsis.zip

# Logs e temporarios
*.log
logs/
**/*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# Historico de execucao (pode ter dados sensiveis)
src-tauri/data/
src-tauri/commands.json
src-tauri/history.json
**/commands.json
**/history.json

# Configuracao de ambiente local (NAO commitar)
.env
.env.local
.env.development
.env.production
.env.*.local
*.pem
*.key
secrets.json

