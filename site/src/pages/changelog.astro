---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const entry = await getEntry('docs', 'changelog');
if (!entry) throw new Error('Documento "changelog" não encontrado em src/content/');

const { Content } = await render(entry);
---
<Base
  title="Changelog — Toolbox"
  description="Histórico de versões e mudanças do Toolbox."
>
  <article class="changelog">
    <Content />
  </article>
</Base>

<style>
  .changelog :global(h1) { margin-bottom: 8px; }
  .changelog :global(h2) {
    margin-top: 40px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .changelog :global(h3) { margin-top: 24px; }
  .changelog :global(ul) { padding-left: 24px; }
  .changelog :global(li) { margin-bottom: 4px; }
</style>
