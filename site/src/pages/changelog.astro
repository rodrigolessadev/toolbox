---
import Base from '../layouts/Base.astro';

// Conteúdo sincronizado a partir de /CHANGELOG.md do monorepo.
// Em produção, considere migrar para @astrojs/mdx com remark-gfm.
import changelogRaw from '../content/CHANGELOG.md?raw';
---

<Base
  title="Changelog — Toolbox"
  description="Histórico de versões e mudanças do Toolbox."
>
  <article class="changelog">
    <h1>Changelog</h1>
    <p class="text-muted">
      Todas as mudanças notáveis neste projeto são documentadas aqui.
      O formato é baseado em <a href="https://keepachangelog.com/pt-BR/1.1.0/">Keep a Changelog</a>.
    </p>

    <pre class="md-source"><code>{changelogRaw}</code></pre>
  </article>
</Base>

<style>
  .changelog h1 { margin-bottom: 12px; }
  .md-source {
    margin-top: 24px;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
