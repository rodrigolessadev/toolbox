---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Toolbox">
  <section class="notfound">
    <h1>404</h1>
    <p>A página que você procurou não existe ou foi movida.</p>
    <a class="btn btn-primary" href="/">Voltar para o início</a>
  </section>
</Base>

<style>
  .notfound {
    text-align: center;
    padding: 80px 0;
  }
  .notfound h1 {
    font-size: 6rem;
    margin: 0;
    color: var(--accent);
  }
  .notfound p {
    color: var(--text-muted);
    margin: 16px 0 32px;
  }
</style>
