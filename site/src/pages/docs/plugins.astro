---
import { getEntry, render } from 'astro:content';
import Docs from '../../layouts/Docs.astro';

const entry = await getEntry('docs', 'plugins');
if (!entry) throw new Error('Documento "plugins" não encontrado em src/content/');

const { Content } = await render(entry);
---
<Docs title="Guia de Plugins — Toolbox" description="Como criar seus próprios plugins em qualquer linguagem.">
  <Content />
</Docs>
