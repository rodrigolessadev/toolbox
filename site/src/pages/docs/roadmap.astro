---
import { getEntry, render } from 'astro:content';
import Docs from '../../layouts/Docs.astro';

const entry = await getEntry('docs', 'roadmap');
if (!entry) throw new Error('Documento "roadmap" não encontrado em src/content/');

const { Content } = await render(entry);
---
<Docs title="O que vem por aí — Toolbox" description="Funcionalidades planejadas para versões futuras.">
  <Content />
</Docs>
