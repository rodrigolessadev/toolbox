---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Base title={title} description={description}>
  <article class="docs">
    <nav class="docs-sidebar">
      <h4>Documentação</h4>
      <ul>
        <li><a href="/docs/commands">Como cadastrar comandos</a></li>
        <li><a href="/docs/architecture">Como o app funciona</a></li>
        <li><a href="/docs/plugins">Guia de Plugins</a></li>
        <li><a href="/docs/roadmap">O que vem por aí</a></li>
        <li><a href="/changelog">Changelog</a></li>
      </ul>
    </nav>
    <div class="docs-content">
      <slot />
    </div>
  </article>
</Base>

<style>
  .docs {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: start;
  }
  .docs-sidebar {
    position: sticky;
    top: 80px;
    border-left: 2px solid var(--border);
    padding-left: 16px;
  }
  .docs-sidebar h4 {
    margin: 0 0 12px;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .docs-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .docs-sidebar a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .docs-sidebar a:hover { color: var(--accent); }

  .docs-content {
    min-width: 0;
  }

  /* ===== Tipografia do conteúdo Markdown ===== */
  .docs-content :global(h1) {
    margin-bottom: 8px;
    font-size: 2.25rem;
    font-weight: 700;
  }
  .docs-content :global(h2) {
    margin-top: 40px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    font-size: 1.625rem;
    font-weight: 600;
  }
  .docs-content :global(h3) {
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .docs-content :global(h4) {
    margin-top: 20px;
    font-size: 1.05rem;
    font-weight: 600;
  }
  .docs-content :global(p) {
    color: var(--text);
    margin: 12px 0;
  }
  .docs-content :global(strong) { color: var(--text); font-weight: 600; }
  .docs-content :global(em) { color: var(--text-muted); }
  .docs-content :global(a) { text-decoration: underline; text-underline-offset: 3px; }

  /* Listas */
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 28px;
    margin: 12px 0;
  }
  .docs-content :global(li) {
    margin-bottom: 6px;
  }
  .docs-content :global(li::marker) {
    color: var(--text-muted);
  }
  .docs-content :global(li > ul),
  .docs-content :global(li > ol) {
    margin: 6px 0;
  }

  /* Tabelas */
  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 0.95rem;
    display: block;
    overflow-x: auto;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    padding: 10px 14px;
    border: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }
  .docs-content :global(th) {
    background: var(--bg-elevated);
    font-weight: 600;
  }
  .docs-content :global(tbody tr:nth-child(even)) {
    background: rgba(255, 255, 255, 0.02);
  }

  /* Bloco de código */
  .docs-content :global(pre) {
    margin: 16px 0;
    padding: 16px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow-x: auto;
    line-height: 1.55;
    font-size: 0.875rem;
  }
  .docs-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  .docs-content :global(:not(pre) > code) {
    background: var(--code-bg);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-size: 0.875em;
  }

  /* Citação (dica em destaque) */
  .docs-content :global(blockquote) {
    margin: 16px 0;
    padding: 12px 18px;
    border-left: 3px solid var(--accent);
    background: var(--bg-elevated);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text-muted);
  }
  .docs-content :global(blockquote p) {
    margin: 4px 0;
  }
  .docs-content :global(blockquote strong) {
    color: var(--text);
  }

  /* Régua horizontal */
  .docs-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  /* Imagens inline */
  .docs-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    margin: 12px 0;
  }

  @media (max-width: 820px) {
    .docs {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .docs-sidebar {
      position: static;
      border-left: none;
      border-bottom: 1px solid var(--border);
      padding-left: 0;
      padding-bottom: 16px;
    }
  }
</style>
