# Copie para .env e preencha com seus valores.
# Em produção, configure no painel da Vercel (Project Settings → Environment Variables).

# Dono/repo no GitHub, ex: rodrigo/toolbox
PUBLIC_GITHUB_REPO=seu-usuario/toolbox

# URL pública do site (opcional, sobrescreve o valor de astro.config.mjs)
PUBLIC_SITE_URL=https://toolbox.seudominio.com.br
